<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#4f46e5" />
    <title>Dashboard • Personal Document Vault</title>
    <link rel="icon" href="/images/favicon.jpg" type="image/jpeg" />
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body class="dashboard-page">
    <header class="topbar container-fluid">
      <div>
        <p class="eyebrow">Document Locker</p>
        <h1>Personal Document Vault</h1>
        <p class="subtext">Securely upload, organize, and manage your important files in one place.</p>
      </div>
      <div class="topbar-actions">
        <button id="themeToggle" class="ghost">🌙</button>
        <form method="POST" action="/logout">
          <button class="ghost">Logout</button>
        </form>
      </div>
    </header>

    <main class="dashboard container-fluid">
      <section class="hero-grid">
        <article class="profile-card card full-width-card hero-profile-card">
          <div class="hero-profile-content">
            <div class="hero-profile-copy">
              <p class="eyebrow">Hello</p>
              <h2>I'm <span><%= user.username %></span>,<br />your private document space.</h2>
              <p class="hero-subtext">Keep your important files protected, organised, and ready whenever you need them.</p>
              <div class="hero-actions">
                <a class="hero-button primary" href="#upload">Upload File <span>→</span></a>
                <a class="hero-button secondary" href="#documents">View Documents</a>
              </div>
              <div class="hero-stats">
                <div class="hero-stat">
                  <strong><%= totalDocuments %></strong>
                  <span>Documents</span>
                </div>
                <div class="hero-stat">
                  <strong><%= totalCategories %></strong>
                  <span>Categories</span>
                </div>
              </div>
            </div>
            <div class="hero-profile-visual">
              <span class="hero-vertical-label" aria-hidden="true">VAULT</span>
              <div class="hero-image-frame">
                <img src="/images/profile.png" alt="<%= user.username %>" class="hero-image" />
              </div>
              <div class="hero-highlight-card">
                <p>Secure vault</p>
                <strong><i></i> Active</strong>
              </div>
            </div>
          </div>
        </article>

        <aside class="feature-panel card full-width-card">
          <div class="feature-header">
            <p class="eyebrow">Vault features</p>
            <h2>What you can do</h2>
          </div>
          <div class="feature-grid">
            <article class="feature-card">
              <p class="feature-title">Upload files</p>
              <span>Save documents to local storage or cloud options.</span>
            </article>
            <article class="feature-card">
              <p class="feature-title">Organize categories</p>
              <span>Quickly sort documents into the right groups.</span>
            </article>
            <article class="feature-card">
              <p class="feature-title">Search instantly</p>
              <span>Find items by file name, category, type, or date.</span>
            </article>
            <article class="feature-card">
              <p class="feature-title">Manage securely</p>
              <span>Rename, download, preview, and delete safely.</span>
            </article>
          </div>
        </aside>
      </section>

      <section id="upload" class="card action-card full-width-card">
        <div class="section-title">
          <div>
            <h3>Quick Upload</h3>
            <p class="muted">Upload a file and assign it to the right category.</p>
          </div>
        </div>
        <form method="POST" action="/documents/upload" class="upload-form" enctype="multipart/form-data">
          <input type="file" name="file" required />
          <input name="customCategory" placeholder="Custom category (optional)" />
          <select name="category">
            <% categories.forEach((category) => { %>
              <option value="<%= category %>"><%= category %></option>
            <% }) %>
          </select>
          <select name="storage">
            <option value="Google Drive">Google Drive</option>
            <option value="Local">Local (fallback)</option>
          </select>
          <button type="submit">Upload Document</button>
        </form>
      </section>

      <section class="panel-grid full-width-card">
        <article class="card stats-card">
          <h3>Storage Summary</h3>
          <div class="stats-row">
            <div>
              <p>Google Drive</p>
              <strong><%= storageSummary['Google Drive'] %></strong>
            </div>
            <div>
              <p>Local</p>
              <strong><%= storageSummary.Local %></strong>
            </div>
          </div>
        </article>

        <article class="card stats-card">
          <h3>Recent Uploads</h3>
          <ul class="recent-list">
            <% if (recentDocuments.length === 0) { %>
              <li class="recent-empty">No uploads yet.</li>
            <% } %>
            <% recentDocuments.forEach((doc) => { %>
              <li>
                <span><%= doc.name %></span>
                <small><%= new Date(doc.uploadedAt).toLocaleDateString() %></small>
              </li>
            <% }) %>
          </ul>
        </article>
      </section>

      <section class="card full-width-card">
        <div class="section-title">
          <h3>Categories</h3>
        </div>
        <div class="category-grid">
          <% categories.forEach((category) => { %>
            <article class="category-card">
              <h4><%= category %></h4>
              <p><%= documents.filter((doc) => doc.category === category).length %> documents</p>
            </article>
          <% }) %>
        </div>
      </section>

      <section id="documents" class="card full-width-card">
        <div class="section-title">
          <h3>Documents</h3>
        </div>
        <div class="document-list">
          <% if (documents.length === 0) { %>
            <div class="empty-state">
              <p>No documents uploaded yet. Use the quick upload form to add your first secure file.</p>
            </div>
          <% } %>
          <% documents.forEach((doc) => { %>
            <article class="document-item">
              <div class="document-meta">
                <div>
                  <h4><%= doc.name %></h4>
                  <p><%= doc.category %> • <%= doc.storage %></p>
                </div>
                <span class="badge"><%= doc.type %></span>
              </div>
              <div class="document-actions">
                <a class="action-link" href="/documents/<%= doc.id %>/preview" target="_blank">Preview</a>
                <a class="action-link" href="/documents/<%= doc.id %>/download">Download</a>
                <form method="POST" action="/documents/<%= doc.id %>/delete">
                  <button class="danger" type="submit">Delete</button>
                </form>
              </div>
            </article>
          <% }) %>
        </div>
      </section>
    </main>
    <script src="/js/app.js"></script>
  </body>
</html>
