# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Auth ─────────────────────────────────────────────────────────────────────
SESSION_SECRET=change-this-to-a-long-random-string
VAULT_USERNAME=your_username
VAULT_PASSWORD=your_strong_password

# ── Google Drive ──────────────────────────────────────────────────────────────
# ID of the Drive folder where files will be uploaded.
# Get it from the URL: drive.google.com/drive/folders/<FOLDER_ID>
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id

# Path to your Google service account JSON key file (local dev only).
# On Render / Railway: use GOOGLE_SERVICE_ACCOUNT_JSON instead (see below).
GOOGLE_APPLICATION_CREDENTIALS=./gdrive-service-account.json

# Paste the FULL contents of your service account JSON here when deploying
# to platforms that only accept env vars (e.g. Render, Railway).
# Leave blank for local dev where you use a key file instead.
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── Uploads ───────────────────────────────────────────────────────────────────
UPLOAD_LIMIT_MB=10
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png,doc,docx
